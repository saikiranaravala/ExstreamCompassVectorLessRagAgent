# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# LLM Models
REASONING_MODEL=deepseek-v4
SUMMARIZATION_MODEL=deepseek-v4

# Documentation
DOCS_ROOT=docs
ATLAS_PATH=.atlas
INDEX_JSON_PATH=.atlas/index.json

# Budget Constraints
MAX_TOOL_CALLS_PER_QUERY=20
MAX_FILE_READS_PER_QUERY=8

# API Configuration
API_TITLE=Compass RAG
API_VERSION=0.0.1
DEBUG=false

# OIDC Authentication (optional - if not set, falls back to basic auth)
# Format: provider_name,client_id,client_secret,discovery_url,redirect_uri
# Multiple providers can be configured as separate env vars
# OIDC_AZURE_AD=azure,<client_id>,<client_secret>,https://<tenant>.b2clogin.com/<tenant>/<policy>/v2.0/.well-known/openid-configuration,http://localhost:8000/auth/callback
# OIDC_OKTA=okta,<client_id>,<client_secret>,https://<domain>/.well-known/openid-configuration,http://localhost:8000/auth/callback
# OIDC_GOOGLE=google,<client_id>,<client_secret>,https://accounts.google.com/.well-known/openid-configuration,http://localhost:8000/auth/callback
